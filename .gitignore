# Python 字节码和缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.python-version

# 虚拟环境
venv/
env/
ENV/
.venv
.env
.conda/
conda-env/
myblog_env/

# Conda 环境配置文件
environment.yml
conda-requirements.txt

# Flask 相关
instance/                # 整个 instance 目录忽略（包含所有数据库文件）
.webassets-cache
.flaskenv

# 数据库（双重保险）
*.db
*.sqlite
*.sqlite3
*.sqlite-journal

# 上传文件（保留目录结构，忽略具体文件）
app/static/images/*
!app/static/images/.gitkeep
app/static/images/avatars/*
!app/static/images/avatars/.gitkeep

# 日志
logs/
*.log

# 编辑器/IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# 项目临时文件
*.bak
*.tmp

# 本地测试数据（额外）
test.db